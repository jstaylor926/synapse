# Cockpit build-time env (Vite). Copy to `.env.local` and uncomment to override.
# `.env.local` is git-ignored; this `.example` is the documented template.

# Gate the cockpit to kernel-wired ("ready") views only.
#   1 = show only working features (Ask) — recommended for local testing
#   0 = show every view, including the presentational mocks
# Unset falls back to the policy default in src/featureFlags.ts.
# VITE_SYNAPSE_ONLY_READY=1

# REST edge base URL (defaults to http://127.0.0.1:8765 — see @synapse/client).
# VITE_SYNAPSE_API_BASE=http://127.0.0.1:8765
