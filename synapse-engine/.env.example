# Copy to .env and edit. The engine runs with ALL of these unset (offline mode).

# --- Storage ---
SYNAPSE_DATA_DIR=./data
SYNAPSE_VAULT_DIR=./data/vault          # markdown knowledge base = source of truth

# --- Embeddings ---
# hash = offline deterministic (default, no key). Swap to a real provider later.
SYNAPSE_EMBED_PROVIDER=hash
SYNAPSE_EMBED_DIM=512

# --- LLM ---
# extractive = no generation, answers are stitched from retrieved text (default).
# anthropic  = real generation (requires `pip install -e .[llm]` and a key).
SYNAPSE_LLM_PROVIDER=extractive
# ANTHROPIC_API_KEY=sk-ant-...
# SYNAPSE_LLM_MODEL=claude-sonnet-4-6

# --- Retrieval ---
SYNAPSE_TOP_K=5
