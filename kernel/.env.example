# Kernel configuration (copy to .env). All keys are SYNAPSE_-prefixed.
# Paths default to the repo-local ../data tree; override if your vault lives elsewhere.

# SYNAPSE_VAULT_DIR=../data/vault
# SYNAPSE_DB_DIR=../data/db

# REST edge bind address (consumed by the glasses bridge).
# SYNAPSE_API_HOST=127.0.0.1
# SYNAPSE_API_PORT=8765

# Local-first model defaults; set ANTHROPIC_API_KEY to upgrade to cloud reasoning.
# SYNAPSE_LLM_MODEL=ollama/llama3.1
# SYNAPSE_ANTHROPIC_API_KEY=
# SYNAPSE_EMBED_MODEL=BAAI/bge-small-en-v1.5
